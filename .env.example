# Production URL (metadata, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://kerfautomation.com

# External Cal link + embed slug (used on the in-app /book page). Full URL with https://
NEXT_PUBLIC_BOOKING_URL=https://cal.com/kerf-automation

# Cal.com embed path (username or username/event-slug) for /book inline scheduler.
# Optional when NEXT_PUBLIC_BOOKING_URL is already a https://cal.com/... URL (path is derived).
NEXT_PUBLIC_CAL_LINK=kerf-automation

# Optional: override in-app booking route (default /book).
# NEXT_PUBLIC_BOOKING_PAGE_PATH=/book

# Optional: contact form route (default /contact).
# NEXT_PUBLIC_CONTACT_PAGE_PATH=/contact

# Optional override for Cal embed accent (defaults to Kerf teal #49babc).
# NEXT_PUBLIC_CAL_BRAND_COLOR=#49babc

# Footer LinkedIn — omit in dev if you prefer; link is hidden when unset.
NEXT_PUBLIC_LINKEDIN_URL=

# Optional: Cloudflare Web Analytics (cookieless). From Pages → Web Analytics.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# CI only — Wrangler (`npm run deploy`). Create an API token with Account → Cloudflare Pages → Edit (and read).
# CLOUDFLARE_API_TOKEN=
